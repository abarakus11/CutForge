# CutForge AI — variáveis de ambiente (futuras integrações)
# Copie para .env.local e preencha conforme integrar o backend.

# YouTube Data API (metadados do vídeo)
# YOUTUBE_API_KEY=

# Worker externo com yt-dlp+ffmpeg (Render/Railway/túnel local) — necessário para download na Vercel
# Local: CLIP_WORKER_URL=http://localhost:3001
# CLIP_WORKER_URL=https://seu-worker.onrender.com

# Provedor de IA para detecção de momentos virais
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Armazenamento em nuvem para cortes renderizados
# CLOUD_STORAGE_BUCKET=
# CLOUD_STORAGE_REGION=

# Banco de dados (histórico, usuários, créditos)
# DATABASE_URL=

# Autenticação
# AUTH_SECRET=
# GOOGLE_CLIENT_ID=
# GITHUB_CLIENT_ID=

# Pagamentos
# STRIPE_SECRET_KEY=
# MERCADO_PAGO_ACCESS_TOKEN=
